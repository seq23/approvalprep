---
import BaseLayout from "../layouts/BaseLayout.astro";
import growthHealth from "../../data/admin/growth_health.json";
import queryUniverse from "../../data/atlas/query_universe.json";
import fanoutMap from "../../data/atlas/fanout_query_map.json";
import atoms from "../../data/atoms/answer_atoms.json";
import answers from "../../data/content/generated_answers.json";
import citationOpportunities from "../../data/intelligence/citation_opportunity_registry.json";
import workflowTrace from "../../data/workflow_traces/latest.json";
import indexingReceipts from "../../data/seo/indexing_receipts.json";
import submissionRegistry from "../../data/seo/submission_registry.json";
import selfHealingLog from "../../data/automation/self_healing_log.json";
import finalBlocks from "../../data/automation/final_block_log.json";
import ContentVelocityDashboard from "../components/admin/ContentVelocityDashboard.astro";
import CitationDashboard from "../components/admin/CitationDashboard.astro";
import IndexingDashboard from "../components/admin/IndexingDashboard.astro";
import CrawlerDashboard from "../components/admin/CrawlerDashboard.astro";
import ConversionDashboard from "../components/admin/ConversionDashboard.astro";
import CitationLedgerPanel from "../components/admin/CitationLedgerPanel.astro";
import BacklinkHandoffPanel from "../components/admin/BacklinkHandoffPanel.astro";
import LifecyclePanel from "../components/admin/LifecyclePanel.astro";
import ApprovalQueuePanel from "../components/admin/ApprovalQueuePanel.astro";
import ExperimentPanel from "../components/admin/ExperimentPanel.astro";
import SafeHarborPanel from "../components/admin/SafeHarborPanel.astro";
import contentVelocity from "../../data/metrics/content_velocity.json";
import citationScoreboard from "../../data/metrics/citation_scoreboard.json";
import indexingScoreboard from "../../data/metrics/indexing_scoreboard.json";
import crawlerScoreboard from "../../data/metrics/crawler_scoreboard.json";
import conversionScoreboard from "../../data/metrics/conversion_scoreboard.json";
import citationCandidates from "../../data/citations/citation_candidates.json";
import confirmedCitations from "../../data/citations/confirmed_citations.json";
import mentionWatchlist from "../../data/citations/mention_watchlist.json";
import backlinkNeeds from "../../data/backlink_handoff/backlink_needs.json";
import contentDecayReport from "../../data/intelligence/content_decay_report.json";
import consolidationPlan from "../../data/content/consolidation_plan.json";
import approvalQueue from "../../data/governance/content_approval_queue.json";
import approvalHistory from "../../data/governance/content_approval_history.json";
import publicReportRegistry from "../../data/reports/public_report_registry.json";
import repurposeRegistry from "../../data/repurposing/repurpose_registry.json";
import experimentRegistry from "../../data/experiments/experiment_registry.json";
import experimentResults from "../../data/experiments/experiment_results.json";
import safeHarborAudit from "../../data/governance/safe_harbor_audit_ledger.json";
import safeHarborRewrites from "../../data/governance/safe_harbor_rewrite_ledger.json";
import sourceDepth from "../../data/citations/claim_source_depth_report.json";
import nonHealableBlockers from "../../data/self_healing/non_healable_blockers.json";

const cockpitStats = [
  ["Indexed query universe", queryUniverse.queries.length],
  ["Fan-out parents", fanoutMap.parent_queries.length],
  ["Answer atoms", atoms.atoms.length],
  ["Generated answer assets", answers.answers.length],
  ["Citation opportunities", citationOpportunities.opportunities.length],
  ["Workflow traces", workflowTrace.workflowCount],
  ["Provider receipts", (submissionRegistry.submissions || []).length + (indexingReceipts.receipts || []).length],
  ["Self-heal log entries", (selfHealingLog.entries || []).length],
  ["Final blocks", (finalBlocks.blocks || []).length]
];
---
<BaseLayout title="Runtime Product Admin - ApprovalPrep" description="ApprovalPrep product administration dashboard." noindex={true}>
  <section class="hero shell admin-hero">
    <p class="eyebrow">Runtime Product Admin</p>
    <h1>ApprovalPrep product dashboard</h1>
    <p class="lead">Manage live, hidden, revoked, draft, and archived products. Upload images and paid downloads. Create Stripe products/prices from backend functions only.</p>
  </section>

  <section class="band"><div class="shell">
    <div class="card admin-card">
      <p class="eyebrow">Growth cockpit</p>
      <h2>SEO / AEO / GEO operating dashboard</h2>
      <p class="fine">These panels show structural readiness and fixture/dry-run traces. They do not claim live rankings, traffic, indexing, or LLM citations without provider telemetry.</p>
      <div class="grid">
        {growthHealth.panels.map((panel) => (
          <article class="card">
            <h3>{panel.name}</h3>
            <p>{panel.status}</p>
          </article>
        ))}
      </div>
      <div class="table-wrap admin-cockpit-table">
        <table>
          <thead><tr><th>System area</th><th>Current count</th></tr></thead>
          <tbody>
            {cockpitStats.map(([label, value]) => <tr><td>{label}</td><td><strong>{value}</strong></td></tr>)}
          </tbody>
        </table>
      </div>
      <div class="notice mini-notice">
        <strong>Operator rule:</strong> use Growth Health, Query Universe, Citation Gaps, Indexing, Self-Healing Log, and Blockers to decide what needs owner attention. Fixture traces prove workflow shape, not live provider success.
      </div>
      <div class="grid measurement-grid">
        <ContentVelocityDashboard title="Content velocity" description="Structural publication output from the current repo." data={contentVelocity} />
        <CitationDashboard title="Citation readiness" description="Citation targets, opportunities, and source coverage without fake confirmed-citation claims." data={citationScoreboard} />
        <IndexingDashboard title="Indexing readiness" description="Sitemap/submission/provider inspection visibility." data={indexingScoreboard} />
        <CrawlerDashboard title="Crawler visibility" description="Owned crawl and external crawler readiness." data={crawlerScoreboard} />
        <ConversionDashboard title="Conversion proof" description="Checkout proof artifacts separated from live conversion analytics." data={conversionScoreboard} />
        <CitationLedgerPanel title="Citation ledger" description="Candidate and confirmed citation records without fake win claims." candidates={citationCandidates} confirmed={confirmedCitations} watchlist={mentionWatchlist} />
        <BacklinkHandoffPanel title="Backlink repo handoff" description="Priority pages, anchors, and safe snippets for the separate backlink workflow." needs={backlinkNeeds} />
        <LifecyclePanel title="Lifecycle control" description="Refresh, pruning, consolidation, and redirect governance for public content surfaces." decay={contentDecayReport} consolidation={consolidationPlan} />
        <ApprovalQueuePanel title="Content approval governance" description="Regulated, credit-sensitive, and high-risk content that must not promote by automation alone." queue={approvalQueue} history={approvalHistory} />
        <ExperimentPanel title="Conversion experiments" description="Approval-gated experiment queue for safe CTA/content improvements." registry={experimentRegistry} results={experimentResults} />
        <SafeHarborPanel title="Safe Harbor autopublish" description="Regulated-adjacent content may autopublish only after deterministic safety gates pass." audit={safeHarborAudit} rewrites={safeHarborRewrites} sources={sourceDepth} blockers={nonHealableBlockers} />
        <article class="card">
          <p class="eyebrow">Authority reports</p>
          <h3>{publicReportRegistry.reports.length} public reports</h3>
          <p>{repurposeRegistry.outputs.length} free repurposed checklist outputs are tracked for public distribution. Reports are methodology-labeled and do not claim live market research, rankings, or approval odds.</p>
        </article>
      </div>

    </div>

    <div id="loginPanel" class="card admin-card">
      <h2>Admin password</h2>
      <p>This screen uses one simple password for the operator. Product mutations are still handled by server-side Cloudflare Functions.</p>
      <input id="adminPassword" type="password" placeholder="Admin password" />
      <button id="loginButton" class="button primary">Unlock admin</button>
      <p id="loginStatus" class="small"></p>
    </div>

    <div id="adminApp" hidden>
      <div class="admin-actions">
        <button class="button" id="refreshProducts">Refresh products</button>
        <button class="button" id="exportRegistry">Export registry JSON</button>
      </div>
      <div class="grid">
        <article class="card"><h3>Live</h3><p id="countLive">0</p></article>
        <article class="card"><h3>Draft</h3><p id="countDraft">0</p></article>
        <article class="card"><h3>Revoked</h3><p id="countRevoked">0</p></article>
      </div>
      <h2>Add product</h2>
      <form id="createProduct" class="admin-form">
        <input name="name" placeholder="Product name" required />
        <input name="price" type="number" min="1" step="0.01" placeholder="Price in dollars" required />
        <input name="shortDescription" placeholder="Short description" />
        <textarea name="longDescription" placeholder="Full description"></textarea>
        <button class="button primary">Create draft product</button>
      </form>

      <h2>Products</h2>
      <div id="productTable" class="admin-table"></div>

      <h2>Upload asset</h2>
      <p class="fine">Images are checked for supported type and product fit, not an arbitrary 2MB ApprovalPrep cap. PDF and DOCX uploads still use the configured document safety limit.</p>
      <form id="uploadAsset" class="admin-form">
        <input name="productId" placeholder="Product slug or ID" required />
        <select name="assetType"><option value="image">Image</option><option value="pdf">PDF</option><option value="docx">DOCX</option></select>
        <input name="file" type="file" required />
        <button class="button primary">Upload asset</button>
      </form>
      <pre id="adminOutput" class="admin-output"></pre>
    </div>
  </div></section>

  <script>
    const state = { token: sessionStorage.getItem('ap_admin_token') || '', products: [] };
    const $ = (id) => document.getElementById(id);
    function headers(){ return { 'content-type':'application/json', 'x-admin-token': state.token }; }
    function print(data){ $('adminOutput').textContent = typeof data === 'string' ? data : JSON.stringify(data,null,2); }
    async function login(){ const password=$('adminPassword').value; const res=await fetch('/api/admin/login',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({password})}); const data=await res.json(); if(!data.ok){ $('loginStatus').textContent=data.error||'Login failed'; return; } state.token=data.token; sessionStorage.setItem('ap_admin_token',state.token); $('loginPanel').hidden=true; $('adminApp').hidden=false; await loadProducts(); }
    async function loadProducts(){ const res=await fetch('/api/admin/products',{headers:{'x-admin-token':state.token}}); const data=await res.json(); if(!data.ok){ print(data); return; } state.products=data.products||[]; renderProducts(); }
    function count(status){ return state.products.filter(p=>p.status===status).length; }
    function renderProducts(){ $('countLive').textContent=count('live'); $('countDraft').textContent=count('draft'); $('countRevoked').textContent=count('revoked'); const rows=state.products.map(p=>`<tr><td><strong>${p.name}</strong><br><small>${p.slug||p.id}</small></td><td>${p.status}</td><td>$${((p.price_cents??p.priceCents??0)/100).toFixed(2)}</td><td>${p.stripe_live_price_id||p.stripeLivePriceId||''}</td><td><button data-action="publish" data-id="${p.id}">Publish</button><button data-action="hide" data-id="${p.id}">Hide</button><button data-action="revoke" data-id="${p.id}">Revoke</button><button data-action="restore" data-id="${p.id}">Restore</button><button data-action="archive" data-id="${p.id}">Archive</button></td></tr>`).join(''); $('productTable').innerHTML=`<table><thead><tr><th>Product</th><th>Status</th><th>Price</th><th>Live price</th><th>Actions</th></tr></thead><tbody>${rows}</tbody></table>`; document.querySelectorAll('[data-action]').forEach(btn=>btn.addEventListener('click',()=>mutate(btn.dataset.action,btn.dataset.id))); }
    async function mutate(action,id){ const body={id}; if(action==='revoke') body.reason=prompt('Reason for revocation')||'Admin revoked checkout'; const res=await fetch(`/api/admin/product-${action}`,{method:'POST',headers:headers(),body:JSON.stringify(body)}); const data=await res.json(); print(data); await loadProducts(); }
    $('loginButton').addEventListener('click',login); $('refreshProducts').addEventListener('click',loadProducts); $('exportRegistry').addEventListener('click',async()=>print(await (await fetch('/api/admin/export-registry',{headers:{'x-admin-token':state.token}})).json()));
    $('createProduct').addEventListener('submit',async(e)=>{ e.preventDefault(); const fd=new FormData(e.target); const body=Object.fromEntries(fd.entries()); const res=await fetch('/api/admin/products',{method:'POST',headers:headers(),body:JSON.stringify(body)}); const data=await res.json(); print(data); await loadProducts(); });
    $('uploadAsset').addEventListener('submit',async(e)=>{ e.preventDefault(); const fd=new FormData(e.target); const res=await fetch('/api/admin/upload',{method:'POST',headers:{'x-admin-token':state.token},body:fd}); const data=await res.json(); print(data); await loadProducts(); });
    if(state.token){ $('loginPanel').hidden=true; $('adminApp').hidden=false; loadProducts(); }
  </script>
</BaseLayout>
