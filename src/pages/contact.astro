---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Contact - ApprovalPrep" description="Contact ApprovalPrep by email." canonical="https://approvalprep.com/contact" showPrivacyNotice={false}>
  <section class="hero shell contact-hero">
    <p class="eyebrow">Contact</p>
    <h1>Email ApprovalPrep.</h1>
    <p class="lead"><a href="mailto:info@approvalprep.com">info@approvalprep.com</a></p>
    <div class="hero-actions">
      <a class="button primary-button" href="mailto:info@approvalprep.com">Email info@approvalprep.com</a>
      <a class="button secondary-button" href="/resources">Browse resources</a>
    </div>
  </section>
</BaseLayout>
