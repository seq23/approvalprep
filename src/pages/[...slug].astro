---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductGrid from "../components/ProductGrid.astro";
import BoundaryNotice from "../components/BoundaryNotice.astro";
import TrustBar from "../components/TrustBar.astro";
import HowItWorks from "../components/HowItWorks.astro";
import OutcomeCTA from "../components/OutcomeCTA.astro";
import UseCaseList from "../components/UseCaseList.astro";
import WhatYouGet from "../components/WhatYouGet.astro";
import FAQBlock from "../components/FAQBlock.astro";
import FinalCTA from "../components/FinalCTA.astro";
import CreditBoundaryExplainer from "../components/CreditBoundaryExplainer.astro";
import NextStepsExplainer from "../components/NextStepsExplainer.astro";
import DataPrivacyNotice from "../components/DataPrivacyNotice.astro";
import OfferingUniverse from "../components/OfferingUniverse.astro";
import IncludedOfferings from "../components/IncludedOfferings.astro";
import PageCTAStack from "../components/PageCTAStack.astro";
import ProblemAgitationFit from "../components/ProblemAgitationFit.astro";
import WhatHappensAfterPurchase from "../components/WhatHappensAfterPurchase.astro";
import TrustAndBoundaryBand from "../components/TrustAndBoundaryBand.astro";
import PricingDeck from "../components/PricingDeck.astro";
import GuidePlaybook from "../components/GuidePlaybook.astro";
import LegalPolicyPage from "../components/LegalPolicyPage.astro";
import RelatedContent from "../components/RelatedContent.astro";
import manifest from "../../data/routes/route_manifest.json";
import { routeCopy, boundary, productCards, productComparison, routeFamilyCopy, offeringCategories, offeringsForSku, productForSku } from "../data/content";

export function getStaticPaths() {
  return manifest.routes
    .filter((route) => !["/", "/letter-writing-studio", "/resources", "/blog", "/contact", "/methodology"].includes(route.path) && !route.path.startsWith("/tools/") && !route.path.startsWith("/templates/") && !route.path.startsWith("/reports/") && route.type !== "admin")
    .map((route) => ({ params: { slug: route.path.slice(1) }, props: { route } }));
}

const { route } = Astro.props;
const copy = routeCopy[route.path] || {
  heading: route.title,
  lead: "Use this page to understand what to prepare, what to send, and what ApprovalPrep does not do.",
  shortAnswer: "ApprovalPrep gives you a plain next step. You stay in control.",
  primaryCta: route.primary_cta || "Start my letter",
  secondaryCta: route.secondary_cta || "Build my packet",
  whoFor: ["People who want to prepare before they apply."],
  value: ["Plain-language guidance."],
  whatYouGet: ["Simple next steps."],
  useCases: ["You need a clearer packet."],
  steps: ["Read the page.", "Use only true facts.", "Review before sending."],
  faq: [{ question: "Does ApprovalPrep do this for me?", answer: "No. ApprovalPrep is self-service. You send your own documents." }],
  trustSignals: ["No account required", "No saved customer documents", "Self-service only", "Plain-language guidance"]
};
const canonical = "https://approvalprep.com" + route.path;
const isCredit = route.family === "credit_self_service" || route.risk === "regulated" || route.path.includes("credit");
const isPricing = route.path === "/pricing";
const isDownload = route.path === "/download" || route.path === "/checkout/success";
const isGlossary = route.path === "/glossary";
const isLegal = route.type === "legal";
const isGuide = route.page_intent === "guide";
const familyCopy = routeFamilyCopy[route.family] || routeFamilyCopy[route.risk === "regulated" ? "credit_self_service" : "letter_studio"];
const skuForRoute = (() => {
  const path = route.path;
  if (path.includes("business") || path.includes("sba")) return "business-funding-prep-kit";
  if (path.includes("apartment") || path.includes("rental") || path.includes("approved-for-an-apartment")) return "rental-application-kit";
  if (path.includes("credit")) return "credit-letter-kit";
  if (path.includes("employment") || path.includes("income")) return "income-employment-letter-kit";
  if (path.includes("auto-loan") || path.includes("car-loan") || path.includes("mortgage") || path.includes("loan")) return "loan-prep-letter-kit";
  if (path.includes("moving") || path.includes("important-documents")) return "life-admin-letter-kit";
  if (path.includes("complete-approvalprep-bundle")) return "complete-approvalprep-bundle";
  return "letter-of-explanation";
})();
const ctaHref = route.cta_policy === "purchase" ? `/pricing#${skuForRoute}` : (route.path.includes("apartment") || route.path.includes("rental") ? "/apartment-application" : "/letter-of-explanation");
const primarySku = route.cta_policy === "purchase" ? skuForRoute : "";
const routeProduct = productForSku(skuForRoute);
const routeOfferings = offeringsForSku(skuForRoute);
const isCommercial = route.cta_policy === "purchase" || route.page_intent === "product";
const primaryCtaWithPrice = primarySku && routeProduct ? `Buy ${routeProduct.name} — ${routeProduct.priceLabel}` : copy.primaryCta;
---
<BaseLayout title={`${route.title} - ApprovalPrep`} description={copy.lead} canonical={canonical} noindex={!route.index}>
  <section class={`hero shell ${isLegal ? "legal-hero" : "hero-split"}`}>
    <div>
      <p class="eyebrow">{familyCopy?.label || route.family.replaceAll("_", " ")}</p>
      <h1>{copy.heading}</h1>
      <p class="lead">{copy.lead}</p>
      {familyCopy?.promise && <p class="supporting-copy">{familyCopy.promise}</p>}
      {!isLegal && !isDownload && <OutcomeCTA primary={primaryCtaWithPrice} secondary={copy.secondaryCta} href={ctaHref} secondaryHref="/pricing" primarySku={primarySku} />}
      <TrustBar signals={copy.trustSignals} />
    </div>
    {!isLegal && (
      <aside class="hero-panel">
        <p class="eyebrow">Before you start</p>
        <h2>Prepare the facts first.</h2>
        <ul class="compact-list">{(familyCopy?.prepare || []).map((item) => <li>{item}</li>)}</ul>
      </aside>
    )}
    {isCredit && <div class="hero-boundary"><CreditBoundaryExplainer /></div>}
    {isDownload && (
      <div class="checkout-success-hero" aria-label="Checkout success confirmation">
        <div class="success-badge" aria-hidden="true">✓</div>
        <p class="eyebrow">Checkout complete</p>
        <h1>Success! Your checkout is complete.</h1>
        <p class="lead">ApprovalPrep is verifying Stripe now. Once verified, your PDF guide and editable DOCX kit unlock on this page.</p>
      </div>
      <div class="notice success-flow-notice">
        <strong>What happens next:</strong>
        <ol class="compact-list">
          <li>Stripe confirms the completed checkout session.</li>
          <li>This page unlocks your protected PDF guide and editable DOCX template kit.</li>
          <li>You choose: download the blank/editable templates now, or open the free Letter Studio to prefill a first-pass draft in your browser.</li>
        </ol>
        <p>If Stripe has not confirmed this checkout session as paid, no paid files are unlocked yet.</p>
      </div>
      <div class="card download-panel" data-download-panel>
        <h2>Your download options</h2>
        <p class="fine" data-download-status>Waiting for Stripe verification. If you just checked out, this should update automatically.</p>
        <div class="download-links" data-download-links></div>
      </div>
    )}
  </section>
  {isDownload ? (
    <>
      <section class="band"><div class="shell">
        <article class="notice">
          <strong>If your download does not appear right away:</strong>
          <p>If Stripe confirms a completed payment, this page unlocks the PDF guide and editable DOCX kit files. Your two choices are clear: download the blank/editable templates immediately, or use the free browser-only Studio to prefill a draft without storing your answers. If Stripe still has the session open or unconfirmed, return to pricing and complete checkout. If Stripe shows a completed payment and you still cannot access your files, email <a href="mailto:info@approvalprep.com">info@approvalprep.com</a> with the receipt and session id shown above.</p>
        </article>
      </div></section>
    </>
  ) : isPricing ? (
    <>
      <section class="band pricing-band"><div class="shell">
        <div class="pricing-header">
          <div>
            <p class="eyebrow">Pricing first</p>
            <h2>Choose the kit that matches the paperwork pressure.</h2>
            <p class="lead">ApprovalPrep has 8 checkout products covering 50 named self-service tools, templates, checklists, and letter types. You do not buy 50 separate files; you choose the kit that contains the paperwork you need, or the Complete Bundle for the full library.</p>
          </div>
          <div class="card pricing-start-free">
            <p class="eyebrow">$0 starting path</p>
            <h3>Not sure yet?</h3>
            <p>Use the free Letter Writing Studio first. It does not store your answers and helps you choose the right kit.</p>
            <a class="button secondary-button" href="/letter-writing-studio">Start free for $0</a>
          </div>
        </div>
        <div class="pricing-model-grid">
          <article class="notice"><strong>How the offers work:</strong><p>Every paid product is a direct paid download. Pick one paid kit below; Stripe unlocks that kit's PDF guide and editable DOCX file. The named offerings listed inside each card are the tools covered by that kit. The $39 Letter of Explanation Kit includes all 9 explanation-letter templates listed in that card.</p></article>
          <article class="notice"><strong>Not ready to buy?</strong><p>Start with the free $0 Studio. It helps you draft a first-pass letter and choose the right paid kit without storing your answers.</p></article>
        </div>
        <div class="card discount-card">
          <div>
            <p class="eyebrow">Discount code</p>
            <h3>Testing or promo code?</h3>
            <p class="fine">Enter a Stripe promotion code before choosing a kit. For test-mode fulfillment, create the Stripe promotion code <strong>TEST100</strong> for 100% off, then enter it here to complete checkout without charging a card.</p>
          </div>
          <label>
            Code
            <input data-discount-code type="text" inputmode="text" autocomplete="off" placeholder="TEST100" />
          </label>
        </div>
        <PricingDeck products={productCards} />
      </div></section>
      <section class="band"><div class="shell">
        <p class="eyebrow">Compare kits</p>
        <h2>Compare by buyer situation.</h2>
        <div class="table-wrap"><table class="comparison-table"><thead><tr><th>Product</th><th>Best for</th><th>Includes</th><th>Price</th></tr></thead><tbody>
          {productComparison.map((row) => <tr><td><a href={row.href}>{row.product}</a></td><td>{row.bestFor}</td><td>{row.includes}</td><td><strong>{row.price}</strong></td></tr>)}
        </tbody></table></div>
      </div></section>
      <section class="band"><div class="shell"><p class="eyebrow">All included offerings</p><h2>50 named self-service tools organized into 8 paid checkout kits.</h2><p class="lead">This is the full universe of named use cases. The Complete Bundle includes the full library; the smaller kits include the tools for that specific situation.</p><OfferingUniverse categories={offeringCategories} /></div></section>
    </>
  ) : isGlossary ? (
    <section class="band"><div class="shell grid">
      <article class="card"><h2>Letter of explanation</h2><p>A short note that explains a gap, issue, or context in plain words.</p></article>
      <article class="card"><h2>Self-service credit tools</h2><p>Tools that help you prepare your own paperwork. They do not fix credit for you.</p></article>
      <article class="card"><h2>Ready-to-Apply Kit</h2><p>A packet with letters, checklists, and next steps for an application.</p></article>
    </div></section>
  ) : isLegal ? (
    <LegalPolicyPage route={route} copy={copy} />
  ) : (
    <>
      <section class="band"><div class="shell"><article class="short-answer card"><p class="eyebrow">Short answer</p><p>{copy.shortAnswer}</p></article></div></section>
      {isGuide && <GuidePlaybook copy={copy} product={routeProduct} ctaHref={ctaHref} />}
      {isCommercial && <PageCTAStack primary={primaryCtaWithPrice} secondary="Start free for $0 first" sku={primarySku} secondaryHref="/letter-writing-studio" />}
      {isCommercial && <ProblemAgitationFit title="Make the situation easier to review." items={[
        {title:"The pressure", copy:"A reviewer is asking for clarity, proof, or context. Sending scattered facts can create more questions."},
        {title:"The better move", copy:"Prepare a clear explanation, attach real supporting documents, and keep a copy trail."},
        {title:"The boundary", copy:"ApprovalPrep gives self-service tools. It does not contact anyone, create fake documents, or promise approval."}
      ]} />}
      {copy.decisionContext && (
        <section class="band"><div class="shell">
          <p class="eyebrow">Decision context</p>
          <h2>What this page helps you decide.</h2>
          <div class="copy-stack">{copy.decisionContext.map((paragraph) => <p>{paragraph}</p>)}</div>
        </div>
        </section>
      )}
      <section class="band"><div class="shell"><WhatYouGet title="Who this is for" items={copy.whoFor} /></div></section>
      <section class="band"><div class="shell"><WhatYouGet title="Product / Guide Value" items={copy.value} /></div></section>
      <section class="band"><div class="shell"><WhatYouGet title="What you get" items={copy.whatYouGet} /></div></section>
      {isCommercial && <IncludedOfferings product={routeProduct} offerings={routeOfferings} />}
      {isCommercial && <WhatHappensAfterPurchase />}
      {copy.prepBrief && <section class="band"><div class="shell"><WhatYouGet title="What to prepare first" items={copy.prepBrief} /></div></section>}
      {familyCopy?.avoid && <section class="band"><div class="shell"><WhatYouGet title="Avoid these mistakes" items={familyCopy.avoid} /></div></section>}
      {copy.commonMistakes && <section class="band"><div class="shell"><WhatYouGet title="Common mistakes this helps prevent" items={copy.commonMistakes} /></div></section>}
      <section class="band"><div class="shell"><HowItWorks steps={copy.steps} /></div></section>
      {copy.reviewChecklist && <section class="band"><div class="shell"><WhatYouGet title="Review before you send" items={copy.reviewChecklist} /></div></section>}
      <section class="band"><div class="shell"><UseCaseList items={copy.useCases} /></div></section>
      <section class="band"><div class="shell"><FAQBlock faq={copy.faq} /></div></section>
      <section class="band"><div class="shell two"><div><h2>What this does not do</h2><p>It does not guarantee approval. It does not create fake documents. It does not contact anyone for you. It does not give legal or financial advice. It does not repair credit for you.</p></div><BoundaryNotice /></div></section>
      <section class="band"><div class="shell"><NextStepsExplainer /></div></section>
      <section class="band"><div class="shell"><DataPrivacyNotice /></div></section>
      {isCommercial && <TrustAndBoundaryBand />}
      <section class="band"><div class="shell"><WhatYouGet title="Why ApprovalPrep" items={["Plain steps", "Truthful templates only", "Clear next steps", "No fake document help"]} /></div></section>
    </>
  )}
  {!isLegal && <FinalCTA primary={primaryCtaWithPrice} secondary={copy.secondaryCta} href={ctaHref} secondaryHref="/pricing" primarySku={primarySku} />}
  <section class="band"><div class="shell">
    <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@type": "FAQPage", mainEntity: copy.faq.map((item) => ({ "@type": "Question", name: item.question, acceptedAnswer: { "@type": "Answer", text: item.answer } })) })}></script>
    <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@type": "HowTo", name: route.title, step: copy.steps.map((step, index) => ({ "@type": "HowToStep", position: index + 1, text: step })) })}></script>
  </div></section>
</BaseLayout>
