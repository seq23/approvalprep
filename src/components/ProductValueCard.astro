---
const { product } = Astro.props;
---
<article class={`card product-card ${product.sku === "complete-approvalprep-bundle" ? "featured-product" : ""}`} id={product.sku}>
  <div class="product-card-header">
    <span class="badge">{product.badge}</span>
    <h3>{product.name}</h3>
    <p>{product.customer_situation}</p>
  </div>
  {product.image && <div class="product-media"><img class="product-image" src={product.image} alt={`${product.name} product preview`} loading="lazy" width="1200" height="900" /></div>}
  <p class="product-outcome"><strong>What you get:</strong> {product.outcome}</p>
  <ul class="product-includes">{(product.includes || []).slice(0,4).map((item) => <li>{item}</li>)}</ul>
  {product.included_offerings && <details class="included-details"><summary>Included in this kit</summary><ul>{product.included_offerings.map((item) => <li>{item}</li>)}</ul></details>}
  <div class="product-purchase-row"><p class="price">{product.priceLabel}</p></div>
  {product.stripe_enabled ? (
    <button class="button primary-button checkout-button" type="button" data-sku={product.sku}>{product.cta_label}</button>
  ) : (
    <a class="button primary-button" href={product.download ? `/download?sku=${product.sku}` : "/pricing"}>{product.cta_label}</a>
  )}
  <p class="fine checkout-status" aria-live="polite"></p>
  <p class="fine">{product.risk_note}</p>
</article>
