---
import { studioBenefits } from "../data/letterStudio";
---
<section class="free-studio-cta band">
  <div class="shell two">
    <div>
      <p class="eyebrow">Optional free draft tool</p>
      <h2>Not ready to buy? Start a first draft for $0.</h2>
      <p class="lead">Use the free Letter Writing Studio to organize your facts, pressure-test what you need to say, and decide which direct-download kit fits. Paid kits do not require the Studio. After checkout, buyers download the PDF guide and editable DOCX files directly.</p>
      <div class="hero-actions">
        <a class="button primary-button" href="/letter-writing-studio">Draft for $0 first</a>
        <a class="button secondary-button" href="/pricing">See paid kits from $39</a>
      </div>
    </div>
    <div class="card">
      <h3>What you can do for free</h3>
      <ul class="compact-list">
        {studioBenefits.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </div>
</section>
