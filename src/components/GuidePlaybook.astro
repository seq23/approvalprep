---
const {
  copy,
  product,
  ctaHref = "/pricing",
  studioHref = "/letter-writing-studio"
} = Astro.props;
const gather = copy.prepBrief?.length ? copy.prepBrief : copy.whatYouGet || [];
const review = copy.reviewChecklist?.length ? copy.reviewChecklist : copy.steps || [];
const avoid = copy.commonMistakes?.length ? copy.commonMistakes : [];
---
<section class="band guide-playbook-band">
  <div class="shell guide-playbook">
    <div class="guide-playbook-intro">
      <p class="eyebrow">Practical guide</p>
      <h2>Use this page to decide what to write, what to attach, and what to avoid.</h2>
      <p class="lead">ApprovalPrep guides are meant to move you from uncertainty to a cleaner self-service packet. They are not legal, financial, lending, or credit repair advice.</p>
      <div class="hero-actions">
        <a class="button primary-button" href={studioHref}>Start free for $0</a>
        <a class="button secondary-button" href={ctaHref}>{product ? `View ${product.name} — ${product.priceLabel}` : "Compare kits and prices"}</a>
      </div>
    </div>
    <div class="guide-playbook-grid">
      <article class="card guide-playbook-card">
        <span>1</span>
        <h3>Use this when</h3>
        <ul>{(copy.whoFor || []).slice(0, 4).map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="card guide-playbook-card">
        <span>2</span>
        <h3>Gather first</h3>
        <ul>{gather.slice(0, 5).map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="card guide-playbook-card">
        <span>3</span>
        <h3>Review before sending</h3>
        <ul>{review.slice(0, 5).map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="card guide-playbook-card warning-card">
        <span>!</span>
        <h3>Avoid</h3>
        <ul>{avoid.slice(0, 5).map((item) => <li>{item}</li>)}</ul>
      </article>
    </div>
  </div>
</section>
