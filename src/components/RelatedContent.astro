---
import graph from "../../data/atlas/internal_link_graph.json";
const { path = "", title = "Related ApprovalPrep resources" } = Astro.props;
const record = graph.records.find((item) => item.path === path);
const links = (record?.links || []).slice(0, 5);
---
{links.length > 0 && (
  <section class="band related-content-band">
    <div class="shell">
      <p class="eyebrow">Keep preparing</p>
      <h2>{title}</h2>
      <div class="resource-grid related-content-grid">
        {links.map((link) => (
          <a class="card resource-card" href={link.href}>
            <span>{link.reason.replaceAll("_", " ")}</span>
            <h3>{link.title}</h3>
            <p>{link.anchorText}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
