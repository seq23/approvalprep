---
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import DataPrivacyNotice from "../components/DataPrivacyNotice.astro";
import StructuredData from "../components/StructuredData.astro";
import AnalyticsEvent from "../components/AnalyticsEvent.astro";
import { navCta, primaryNav, secondaryNav } from "../data/navigation";
const { title = "ApprovalPrep", description = "Self-service approval prep tools.", canonical = "https://approvalprep.com", noindex = false, showPrivacyNotice = true, schema = [] } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@type": "Organization", name: "ApprovalPrep", url: "https://approvalprep.com" })}></script>
    <StructuredData schema={schema} />
  </head>
  <body>
    <header class="site-header">
      <div class="shell nav">
        <a class="brand" href="/">ApprovalPrep</a>
        <nav class="nav-links" aria-label="Primary">
          {primaryNav.map((item) => item.href ? <a href={item.href}>{item.title}</a> : (
            <details class="nav-menu">
              <summary>{item.title}</summary>
              <div class="nav-menu-panel">{item.links.map(([href, label]) => <a href={href}>{label}</a>)}</div>
            </details>
          ))}
          <a class="button nav-cta" href={navCta.href}>{navCta.label}</a>
        </nav>
      </div>
      <nav class="secondary-nav shell" aria-label="Use cases">
        <span>Use cases</span>
        {secondaryNav.map(([href, label]) => <a href={href}>{label}</a>)}
      </nav>
    </header>
    <main><slot /></main>
    <AnalyticsEvent surface="approvalprep" />

    <script is:inline>
      if (!window.__approvalPrepCheckoutBound) {
        window.__approvalPrepCheckoutBound = true;
        document.addEventListener("DOMContentLoaded", () => {
          const params = new URLSearchParams(window.location.search);
          if (params.get("checkout") === "cancelled") {
            const target = document.querySelector("main");
            const note = document.createElement("div");
            note.className = "shell notice checkout-cancelled";
            note.innerHTML = "<strong>Checkout was cancelled.</strong><p>No payment was completed. You can choose a product below and try again when ready.</p>";
            target?.prepend(note);
          }
        });

        document.addEventListener("DOMContentLoaded", async () => {
          const panel = document.querySelector("[data-download-panel]");
          if (!panel) return;
          const status = panel.querySelector("[data-download-status]");
          const links = panel.querySelector("[data-download-links]");
          const params = new URLSearchParams(window.location.search);
          const session_id = params.get("session_id") || "";
          const sku = params.get("sku") || "";
          if (!session_id || !sku) {
            if (status) status.textContent = "No verified Stripe session was found. Return to pricing and complete checkout to unlock downloads.";
            return;
          }
            if (status) status.textContent = "Verifying your payment with Stripe. ApprovalPrep does not store your letter answers or completed customer documents.";
          const verify = async (attempt = 1) => {
            const response = await fetch("/api/verify-download", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ session_id, sku })
            });
            const payload = await response.json().catch(() => ({}));
            if (response.ok && payload.status === "VERIFIED") return payload;
            if ((response.status === 202 || payload.status === "PAYMENT_PENDING") && attempt < 8) {
              if (status) status.textContent = `Stripe is still confirming the payment. Retrying automatically (${attempt}/8)...`;
              await new Promise((resolve) => setTimeout(resolve, 1500 * attempt));
              return verify(attempt + 1);
            }
            if (payload.status === "PAYMENT_NOT_COMPLETED" || response.status === 402) {
              const error = new Error(payload.message || "No completed payment was found for this checkout session.");
              error.code = "PAYMENT_NOT_COMPLETED";
              throw error;
            }
            throw new Error(payload.message || "Payment could not be verified yet. Contact info@approvalprep.com with your Stripe receipt and this session id.");
          };
          try {
            const payload = await verify();
            if (status) status.textContent = "Payment verified. Your files are ready.";
            if (links) {
              links.innerHTML = "";
              for (const file of payload.files || []) {
                const a = document.createElement("a");
                a.className = "button secondary secondary-button";
                a.href = file;
                a.textContent = file.endsWith(".pdf") ? "Download PDF guide" : "Download editable Word document";
                a.setAttribute("download", "");
                links.appendChild(a);
              }
              const support = document.createElement("p");
              support.className = "fine";
              support.textContent = `Choose either path: download the blank/editable kit files now, or use the free browser-only Studio to prefill a draft without storing your answers. Session: ${session_id}`;
              links.appendChild(support);
              const studio = document.createElement("a");
              studio.className = "button secondary secondary-button";
              studio.href = `/letter-writing-studio?sku=${encodeURIComponent(sku)}&source=checkout-success`;
              studio.textContent = "Optional: prefill a draft in the Studio";
              links.appendChild(studio);
            }
          } catch (error) {
            if (status) status.textContent = `${error.message || "Download verification failed."} Session: ${session_id}`;
            if (links && error.code === "PAYMENT_NOT_COMPLETED") {
              links.innerHTML = "";
              const pricing = document.createElement("a");
              pricing.className = "button primary-button";
              pricing.href = "/pricing";
              pricing.textContent = "Return to pricing and complete checkout";
              links.appendChild(pricing);
              const support = document.createElement("p");
              support.className = "fine";
              support.textContent = "ApprovalPrep cannot release paid files until Stripe confirms this session as paid. If Stripe shows a completed payment, email info@approvalprep.com with the receipt and session id.";
              links.appendChild(support);
            }
          }
        });
        document.addEventListener("click", async (event) => {
          const button = event.target.closest(".checkout-button[data-sku]");
          if (!button) return;
          const scope = button.closest(".product-card, .final-cta, .hero, section") || document;
          let status = scope.querySelector(".checkout-status");
          if (!status) {
            status = document.createElement("p");
            status.className = "fine checkout-status";
            status.setAttribute("aria-live", "polite");
            button.insertAdjacentElement("afterend", status);
          }
          const original = button.textContent;
          button.disabled = true;
          button.textContent = "Starting checkout...";
            status.textContent = "Opening secure Stripe checkout. We only send the product SKU and optional discount code to start checkout, not your letter answers or personal document contents.";
          const discountInput = document.querySelector("[data-discount-code]");
          const discount_code = String(discountInput?.value || "").trim();
          try {
            const response = await fetch("/api/create-checkout-session", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ sku: button.dataset.sku, discount_code })
            });
            const payload = await response.json().catch(() => ({}));
            if (!response.ok || !payload.checkoutUrl) {
              throw new Error(payload.message || payload.error || "Checkout is not configured yet.");
            }
            window.location.href = payload.checkoutUrl;
          } catch (error) {
            status.textContent = error.message || "Checkout could not start. Please try again.";
            button.disabled = false;
            button.textContent = original;
          }
        });
      }
    </script>
    {showPrivacyNotice && <DataPrivacyNotice compact={true} />}
    <SiteFooter />
  </body>
</html>
