{
  "schemaVersion": "2.0.0",
  "repo": "approvalprep",
  "policy": {
    "hardFailOn": [
      "broken customer journey",
      "public paid download exposure",
      "unsigned Stripe webhook",
      "fake credit repair or approval claims",
      "thin indexed route copy",
      "thin atlas/query fanout",
      "fake ranking/indexing/citation proof",
      "broken admin/operator workflow",
      "unsafe autopublish/self-heal path",
      "false no-storage or customer document retention claims"
    ],
    "doNotHardFailOn": [
      "missing live provider credentials in sandbox",
      "dry-run indexing receipts",
      "absence of observed LLM citations before telemetry",
      "cosmetic preference without conversion or accessibility impact"
    ]
  },
