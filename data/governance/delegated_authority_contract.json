{
  "schemaVersion": "4.2.2",
  "name": "ApprovalPrep Delegated Authority Contract",
  "defaultRule": "Do not ask Sequoia for routine approval. Decide by contract, self-heal repairable issues, block forbidden issues, and escalate owner-level exceptions only.",
  "statuses": [
    "approved_by_contract",
    "self_healed_by_contract",
    "blocked_by_contract",
    "owner_exception",
    "final_blocked_after_self_heal",
    "approval_required_by_law_or_account"
  ],
  "autoApprovedActions": [
    "routine_low_risk_content_publish",
    "seo_metadata_update",
    "aeo_answer_block_update",
    "geo_entity_clarity_update",
    "sitemap_refresh",
    "llms_txt_refresh",
    "answers_index_refresh",
