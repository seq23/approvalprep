    "create_fake_paystub",
    "create_fake_employment_verification",
    "create_fake_income_document",
    "guarantee_approval",
    "guarantee_credit_score_increase",
    "claim_credit_repair_service",
    "claim_we_contact_bureaus",
    "claim_we_dispute_for_you",
    "remove_accurate_negative_items",
    "claim_citation_win_without_evidence",
    "publish_fixture_data_as_real",
    "expose_secret"
  ],
  "safeRewrites": {
    "claim_credit_repair_service": "We help you prepare your own self-service paperwork. We do not fix credit for you.",
    "claim_we_contact_bureaus": "You prepare and send your own paperwork. ApprovalPrep does not contact bureaus or creditors for you.",
    "create_fake_paystub": "Use truthful proof-of-income documents and an income explanation letter. ApprovalPrep does not create fake income documents.",
    "create_fake_employment_verification": "Use a truthful employment verification request letter or employer-provided verification. ApprovalPrep does not create fake employment documents.",
    "guarantee_approval": "ApprovalPrep helps you prepare. It does not guarantee approval."
  },
  "pricingAuthority": {
    "singleLetterRange": [
      29,
      39
    ],
    "defaultSingleLetter": 39,
    "letterStudioBundle": 79,
    "apartmentKitRange": [
      99,
      149
    ],
    "defaultApartmentKit": 129
  },
  "citationAuthority": {
    "target": 100000,
    "timeframeMonths": 6,
    "guaranteed": false,
    "winsRequireTelemetry": true
  },
  "plainLanguageStandard": {
    "target": "6th grade American consumer average",
    "legalMax": "8th grade when accuracy requires it"
  },
  "ctaAuthority": {
    "rule": "Every useful page may include honest, relevant CTAs. Noindex controls search exposure, not conversion.",
    "blocked": [
      "approval guarantees",
      "credit repair promises",
      "fake urgency",
      "unrelated CTAs"
    ]
  }
